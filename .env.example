# ===== Ping agent configuration =====
# Copy this file to ".env" and fill in the values.

# Bot token from the Discord Developer Portal (Bot -> Reset Token).
DISCORD_TOKEN=

# Comma-separated Discord user IDs allowed to command the bot.
# Get your ID: Discord -> Settings -> Advanced -> enable Developer Mode,
# then right-click your name -> Copy User ID.
ALLOWED_USER_IDS=

# (Optional) Restrict commands to specific channel IDs. Empty = any channel
# the bot can see. Right-click a channel -> Copy Channel ID.
COMMAND_CHANNEL_IDS=

# Command prefix (default "!").
COMMAND_PREFIX=!

# Timeouts (seconds).
SHELL_TIMEOUT=60
CLAUDE_TIMEOUT=600

# Path to the Claude Code CLI. Leave BLANK to auto-detect (PATH + common install
# locations for the current user). Only set it if auto-detection fails.
CLAUDE_BIN=

# Extra args passed to claude when running !claude (unattended autonomy).
# For fully hands-off operation add: --dangerously-skip-permissions
# Leave empty to keep Claude's normal permission prompts (safer).
CLAUDE_EXTRA_ARGS=

# Natural-language brain: when on, plain-English messages (not starting with the
# prefix) are interpreted by the Claude CLI and turned into actions.
NL_ENABLED=true
ROUTER_MODEL=claude-haiku-4-5-20251001
ROUTER_TIMEOUT=60

# Working directory the agent operates in. Leave BLANK to use the project folder
# (where the code lives) - correct on any device.
WORKDIR=

# Vision agent loop: for multi-step tasks, Claude sees a fresh screenshot after
# every action and decides the next one. AGENT_MODEL must be a vision model.
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_STEPS=15
AGENT_STEP_DELAY=1.2
AGENT_STEP_TIMEOUT=120
# Screenshot width shown to Claude (~1280 = best click accuracy). Grid spacing px.
AGENT_IMAGE_WIDTH=1280
AGENT_GRID=100
# Click-accuracy debugging: post an annotated overlay (marker at the computed
# click point) on every agent step. Toggle live with !clickdebug on/off.
AGENT_DEBUG_CLICKS=false
# Maximize the target window before each agent step so clicks/typing hit a large,
# predictable layout (stops stray clicks near the title bar from minimizing the
# app while reaching the message box). Toggle live with !maximize on/off.
AGENT_MAXIMIZE_ACTIVE=true

# Discord desktop client updater (used for Phase 3 live screen-share). Leave
# BLANK to auto-detect under %LOCALAPPDATA%\Discord.
DISCORD_UPDATE_EXE=

# ===== Local status dashboard (web page in the bot's own loop) =====
DASHBOARD_ENABLED=true
# Bind address. 127.0.0.1 = this PC only (safe default); 0.0.0.0 = LAN-visible.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765
# How often the page polls status (seconds) and refreshes the screenshot (0=off).
DASHBOARD_REFRESH=30
DASHBOARD_SHOT=300
DASHBOARD_SHOT_MONITOR=1

# ===== Live self-test (run from Discord: !selftest) =====
# Targets for the messaging regression scenarios. Sends are real but tagged with
# SELFTEST_TAG so the pings are obviously tests. No second bot needed.
SELFTEST_TARGET_PERSON=Karan Shrivastava
SELFTEST_SERVER_CHAT=general
SELFTEST_TAG=[ping-selftest]
